# Required for EVM/Solana portfolio, wallet feed, and FIFO PnL
ZERION_API_KEY=

# GMGN read-only skills: market, token research, public tracking, wallet stats.
# Never add GMGN_PRIVATE_KEY to this web application or Vercel.
GMGN_API_KEY=

# Recommended production RPC endpoints (Alchemy, QuickNode, Infura, or Helius)
ETHEREUM_RPC_URL=
BASE_RPC_URL=
